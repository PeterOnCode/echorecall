# OpenAI TTS key (server-only). Optional — can also be set in the Settings tab.
NUXT_OPENAI_API_KEY=sk-your-key-here

# Optional, defaults to ./data
NUXT_DATA_DIR=

# 32+ char secret enabling encrypted in-app OpenAI key storage (US8).
# If unset, the Settings key controls are disabled and the env key above is used.
NUXT_APP_SECRET=

# Default tag values are no longer configured here — set them in the Settings tab
# (Default tag values), persisted in the app. The former NUXT_DEFAULT_TAG_* variables
# are no longer read.
