# OpenAI TTS key (server-only). Optional — can also be set in the Settings tab.
NUXT_OPENAI_API_KEY=sk-your-key-here

# Optional, defaults to ./data
NUXT_DATA_DIR=

# 32+ char secret enabling encrypted in-app OpenAI key storage (US8).
# If unset, the Settings key controls are disabled and the env key above is used.
NUXT_APP_SECRET=

# Optional default tag values pre-filled on new generations (US10). Title is never defaulted.
# Invalid/missing values simply leave the field blank.
NUXT_DEFAULT_TAG_ARTIST=
NUXT_DEFAULT_TAG_ALBUM=
NUXT_DEFAULT_TAG_GENRE=
NUXT_DEFAULT_TAG_COMMENT=
NUXT_DEFAULT_TAG_LANGUAGES=
